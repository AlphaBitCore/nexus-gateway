{
  "name": "@nexus-gateway/agent-dashboard-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus Agent Dashboard frontend. Hosted inside a Wails WebView window; talks to the local agent daemon via Wails-generated Go bindings (no outbound HTTP).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@nexus-gateway/ui-shared": "*",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "i18next": "^26.3.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
